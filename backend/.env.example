# ==============================================================================
# PHQ Complaint Dashboard - Backend Environment Variables
# ==============================================================================
# This is the template used by install.bat to generate backend\.env
# DO NOT put real secrets here - this file is safe to commit to git
# install.bat will auto-fill all values from your answers during setup
# ==============================================================================

# PostgreSQL connection (auto-filled by install.bat)
DATABASE_URL="postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/phq_dashboard?schema=public"
DIRECT_URL="postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/phq_dashboard?schema=public"

# JWT Secret
JWT_SECRET="phq-dashboard-secret-key-2024"

# Server Port (auto-filled by install.bat)
PORT=3001

# Environment
NODE_ENV=production

# CCTNS Haryana Police API
CCTNS_SECRET_KEY=UserHryDashboard
CCTNS_DECRYPT_KEY=your_decrypt_key_here
CCTNS_TOKEN_API=http://api.haryanapolice.gov.in/cmDashboard/api/HomeDashboard/ReqToken
CCTNS_COMPLAINT_API=http://api.haryanapolice.gov.in/phqdashboard/api/PHQDashboard/ComplaintData

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

model Admin {
  id         Int      @id @default(autoincrement())
  username   String   @unique
  password   String
  role       String   @default("admin")
  districtId String?  // For district role: stores district DB id (BigInt as string)
  rangeId    String?  // For range role: stores range key e.g. "karnal", "hisar"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Complaint {
  id                    Int      @id @default(autoincrement())
  complRegNum           String   @unique
  complRegDt            DateTime?
  districtMasterId      BigInt?
  policeStationMasterId BigInt?
  officeMasterId        BigInt?
  districtName          String?
  complDesc             String?
  complSrno             String?
  firstName             String?
  lastName              String?
  mobile                String?
  gender                String?
  age                   Int?
  addressLine1          String?
  addressLine2          String?
  addressLine3          String?
  village               String?
  tehsil                String?
  addressDistrict       String?
  addressPs             String?
  receptionMode         String?
  incidentType          String?
  incidentPlc           String?
  incidentFromDt        DateTime?
  incidentToDt          DateTime?
  submitPsCd            String?
  submitOfficeCd        String?
  email                 String?
  statusRaw             String?
  statusOfComplaint     String?
  statusGroup           String   @default("unknown")
  disposalDate          DateTime?
  isDisposedMissingDate Boolean  @default(false)
  classOfIncident       String?
  complaintSource       String?
  typeOfComplaint       String?
  crimeCategory         String?
  complainantType       String?
  complaintPurpose      String?
  ioDetails             String?
  respondentCategories  String?
  transferDistrictCd    String?
  transferOfficeCd      String?
  transferPsCd          String?
  branch                String?
  firNumber             String?
  actionTaken           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([complRegDt])
  @@index([districtMasterId])
  @@index([policeStationMasterId])
  @@index([officeMasterId])
  @@index([districtName])
  @@index([addressDistrict])
  @@index([statusGroup])
  @@index([isDisposedMissingDate])
  @@index([classOfIncident])
  @@index([crimeCategory])
  @@index([typeOfComplaint])
  @@index([complaintSource])
}

model District {
  id        BigInt   @id
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PoliceStation {
  id           BigInt   @id
  districtId   BigInt?
  districtName String?
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([districtId])
  @@index([districtName])
}

model Office {
  id           BigInt   @id
  name         String
  districtId   BigInt?
  districtName String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([districtId])
  @@index([districtName])
}

model SyncRun {
  id           Int      @id @default(autoincrement())
  kind         String
  status       String
  startedAt    DateTime @default(now())
  endedAt      DateTime?
  fetchedCount Int      @default(0)
  upsertedCount Int     @default(0)
  errorCount   Int      @default(0)
  message      String?
  timeFrom     String?
  timeTo       String?
  syncType     String?
  createdAt    DateTime @default(now())

  @@index([kind])
  @@index([status])
  @@index([startedAt])
}
